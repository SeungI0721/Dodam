<?xml version="1.0" encoding="utf-8"?>
<!-- 도담이 챗봇 빠른 질문 버튼 배경을 정의하는 drawable 리소스 파일이다. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#E0F2FE" />
    <corners android:radius="18dp" />
    <stroke
        android:width="1dp"
        android:color="#7DD3FC" />
    <padding
        android:left="10dp"
        android:top="4dp"
        android:right="10dp"
        android:bottom="4dp" />
</shape>
