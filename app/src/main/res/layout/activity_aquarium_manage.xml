<?xml version="1.0" encoding="utf-8"?>
<!-- 수조 등록, 수정, 삭제 화면을 구성하는 반응형 레이아웃 파일이다. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="수조 관리"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_aquarium_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="#FFFFFFFF"
                android:hint="수조 이름"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <EditText
                android:id="@+id/et_device_id"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFFFF"
                android:hint="장치 ID"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_save_aquarium"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="#4B7BEC"
                    android:text="저장"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_delete_aquarium"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="삭제" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_aquarium_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="#FFFFFFFF"
                android:minHeight="180dp"
                android:padding="16dp"
                android:text="등록된 수조가 없습니다."
                android:textColor="#333333"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_back"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="뒤로가기" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
