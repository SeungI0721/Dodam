<?xml version="1.0" encoding="utf-8"?>
<!-- 커뮤니티 게시글 작성 화면을 구성하는 반응형 레이아웃 파일이다. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fitsSystemWindows="true"
    android:padding="16dp">

    <TextView
        android:id="@+id/post_write_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="게시글 작성"
        android:textColor="#111111"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/tv_main"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:background="#FFFFFFFF"
        android:hint="제목을 입력하세요"
        android:imeOptions="actionNext"
        android:inputType="textCapSentences|textMultiLine|textNoSuggestions"
        android:maxLines="2"
        android:minLines="1"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:scrollHorizontally="false"
        android:textColor="#111111"
        android:textColorHint="#777777"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/post_write_title" />

    <EditText
        android:id="@+id/tv_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#FFFFFFFF"
        android:gravity="top|start"
        android:hint="내용을 입력하세요"
        android:imeOptions="flagNoExtractUi"
        android:inputType="textMultiLine|textCapSentences|textNoSuggestions"
        android:minLines="8"
        android:padding="14dp"
        android:scrollHorizontally="false"
        android:textColor="#111111"
        android:textColorHint="#777777"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@id/post_write_buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_main" />

    <LinearLayout
        android:id="@+id/post_write_buttons"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btu_back"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bt_return"
            android:text="" />

        <Button
            android:id="@+id/btu_pos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bt_posting"
            android:text="" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
