<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/back_ground" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/pannel" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:minHeight="680dp"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="88dp"
            android:paddingEnd="28dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        android:src="@drawable/tv_register_id" />

                    <EditText
                        android:id="@+id/et_id"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="28dp"
                        android:layout_marginEnd="18dp"
                        android:background="@android:color/transparent"
                        android:hint="아이디"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="#000000"
                        android:textColorHint="#A566FF" />
                </FrameLayout>

                <Button
                    android:id="@+id/btn_check"
                    android:layout_width="78dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/check"
                    android:text="" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="아이디 중복 확인 후 가입할 수 있습니다."
                android:textColor="#751985"
                android:textSize="14sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/tv_register" />

                <EditText
                    android:id="@+id/et_mail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="38dp"
                    android:layout_marginEnd="18dp"
                    android:background="@android:color/transparent"
                    android:hint="이메일"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:textColor="#000000"
                    android:textColorHint="#A566FF" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="10dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/tv_register" />

                <EditText
                    android:id="@+id/et_pass"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="38dp"
                    android:layout_marginEnd="18dp"
                    android:background="@android:color/transparent"
                    android:hint="비밀번호"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="#000000"
                    android:textColorHint="#A566FF" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="10dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/tv_register" />

                <EditText
                    android:id="@+id/et_pass2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="38dp"
                    android:layout_marginEnd="18dp"
                    android:background="@android:color/transparent"
                    android:hint="비밀번호 확인"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="#000000"
                    android:textColorHint="#A566FF" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="10dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/tv_register" />

                <EditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="38dp"
                    android:layout_marginEnd="18dp"
                    android:background="@android:color/transparent"
                    android:hint="닉네임"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:textColor="#000000"
                    android:textColorHint="#A566FF" />
            </FrameLayout>

            <CheckBox
                android:id="@+id/cb_check"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="입력한 정보를 확인했습니다."
                android:textColor="#5E2068" />

            <Button
                android:id="@+id/btn_register"
                android:layout_width="176dp"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bt_register"
                android:text="" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
