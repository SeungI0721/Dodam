<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/back_ground" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/setting_pannel" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:minHeight="640dp"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="112dp"
            android:paddingEnd="28dp"
            android:paddingBottom="100dp">

            <EditText
                android:id="@+id/tv_suon"
                android:layout_width="120dp"
                android:layout_height="44dp"
                android:background="@drawable/tv_set"
                android:gravity="center"
                android:hint="26"
                android:inputType="numberDecimal"
                android:maxLines="1"
                android:textColor="#000000"
                android:textColorHint="#3E3E3E"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btu_heater"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bt_off"
                android:text="" />

            <Button
                android:id="@+id/btu_wq_m"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bt_off"
                android:text="수질 수동"
                android:textColor="#000000"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btu_wq_t"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bt_off"
                android:text="수질 자동"
                android:textColor="#000000"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btu_wl_m"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bt_off"
                android:text="수위 수동"
                android:textColor="#000000"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btu_wl_t"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bt_off"
                android:text="수위 자동"
                android:textColor="#000000"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/li_on"
                android:layout_width="150dp"
                android:layout_height="48dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/tv_set"
                android:gravity="center"
                android:hint="켜짐"
                android:inputType="time"
                android:maxLines="1"
                android:textColor="#000000"
                android:textColorHint="#3E3E3E" />

            <EditText
                android:id="@+id/li_off"
                android:layout_width="150dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/tv_set"
                android:gravity="center"
                android:hint="꺼짐"
                android:inputType="time"
                android:maxLines="1"
                android:textColor="#000000"
                android:textColorHint="#3E3E3E" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btu_bac"
        android:layout_width="120dp"
        android:layout_height="92dp"
        android:layout_gravity="bottom|start"
        android:background="@drawable/bt_return"
        android:text="" />

    <Button
        android:id="@+id/btu_sa"
        android:layout_width="120dp"
        android:layout_height="92dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/bt_set"
        android:text="" />
</FrameLayout>
